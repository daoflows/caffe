# ==============================================================================
# .dockerignore — 排除不需要发送到 Docker 构建上下文的文件
# ==============================================================================

# Git
.git/
.gitignore
.gitattributes

# Trae / IDE
.trae/
.specify/
.codebuddy/

# Docker 构建缓存
docker/**/build/
docker/**/dist/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
.eggs/
dist/
build/
*.whl

# Caffe 构建产物 (在容器内编译)
caffex/build/
caffex/distribute/
caffex/.build_release/

# 文档
*.md
!README.md
!docker/**/*.md

# 镜像/数据
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.h5
*.hdf5
*.caffemodel
*.solverstate
*.binaryproto
*.npy
*.npz
*.tar
*.tar.gz
*.tgz
*.zip

# 测试数据
caffex/data/
caffex/examples/
caffex/models/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 日志
*.log

# 临时文件
tmp/
temp/
*.tmp

# MATLAB
caffex/matlab/

# 文档
caffex/docs/